# ── Source chain RPCs ─────────────────────────────────────────────────────
ETHEREUM_RPC=https://eth.llamarpc.com
POLYGON_RPC=https://polygon-rpc.com
SOLANA_RPC=https://api.mainnet-beta.solana.com

# ── EVM bridge addresses ──────────────────────────────────────────────────
ETHEREUM_BRIDGE=0x0000000000000000000000000000000000000000
POLYGON_BRIDGE=0x0000000000000000000000000000000000000000

# ── Stellar ───────────────────────────────────────────────────────────────
STELLAR_RPC=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_CONTROLLER=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQAHHAGK3YNS
RELAYER_SECRET=S...  # Stellar secret key of the bridge relayer

# ── Attester quorum ───────────────────────────────────────────────────────
# 32-byte ed25519 SECRET keys (the same curve Soroban uses natively), hex-encoded
# (64 hex chars per key, with the `0x` prefix). Each key must match the
# corresponding ed25519 PUBLIC key registered as `Bridge` in the on-chain
# `lending_controller` (DataKey::Bridge: BytesN<32>).
ATTESTER_KEYS=0x..,0x..,0x..
ATTESTER_THRESHOLD=2

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://openlend:openlend@localhost:5432/bridge

# ── Misc ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
POLL_INTERVAL_MS=4000
PORT=4100

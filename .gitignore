# ────── Node / JS / TS ──────
node_modules/
dist/
build/
.next/
.turbo/
out/
coverage/
*.tsbuildinfo
.pnpm-store/

# Lockfile policy: commit for published packages (sdk), ignore for
# internal-only subprojects (evm-contracts). The `!sdk/package-lock.json`
# negation must come AFTER the `sdk/package-lock.json` ignore rule for
# the re-include to take effect (later .gitignore rules override earlier
# ones).
sdk/package-lock.json
!sdk/package-lock.json
evm-contracts/package-lock.json

# ────── Rust / Soroban ──────
target/
Cargo.lock
**/*.rs.bk
*.wasm
.soroban/

# ────── Solidity / Hardhat ──────
artifacts/
cache/
typechain-types/
.openzeppelin/

# ────── Environment / Secrets ──────
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ────── Logs / OS ──────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ────── Test / Coverage ──────
coverage/
.nyc_output/
lcov.info

# ────── Docker / K8s ──────
infra/.volumes/
infra/data/
*.pid

# ────── DB dumps ──────
*.sql.gz
*.dump
